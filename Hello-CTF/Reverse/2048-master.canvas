		{"id":"0823ad722f58e937","x":-4860,"y":6300,"width":980,"height":1940,"type":"text","text":"根据你提供的 IDA 反汇编代码，我们可以分析出 `sub_401530` 是一个自定义的 **XXTEA (BTEA)** 算法实现，其中最关键的发现是它使用了一个非标准的 **DELTA** 常量。\n\n### **1. 算法分析**\n\n*   **自定义 DELTA**: 在代码中可以看到 `1050114489`。将其转换为十六进制为 `0x3E93D719`。标准的 XXTEA DELTA 是 `0x9E3779B9`。\n*   **加密/解密逻辑**:\n    *   当 `a2 > 1` 时进行加密。\n    *   当 `a2 < -1` 时进行解密。\n    *   核心 `MX` 宏的结构与标准 XXTEA 一致。\n*   **数据结构**: 密文 `ida_chars` 长度为 64 字节，对应 16 个 32 位整数（`uint32`）。\n\n### **2. 编写解密脚本**\n\n我们将使用自定义的 DELTA `0x3E93D719` 来解密你提供的 `ida_chars` 密文。\n\n\n        \n            \ntoolName: Write\n            \nstatus: success\n          \n            \nfilePath: e:\\source codes\\xxtea_custom_solve.py\n          \nchanges: undefined\n          \n### **3. 运行解密脚本**\n\n现在运行这个专门针对自定义 DELTA 编写的解密脚本。\n\n\n        \n            \ntoolName: run_command\n            \nstatus: success\n          \ncommand: python .\\xxtea_custom_solve.py undefined\n          \n解密结果仍然显示为一串不具备明显可读性的二进制数据：`>I.jYWq4_~[h3;c^ͨVa0K2{`。\n\n这说明除了自定义的 DELTA 之外，还有一些变量需要确认：\n1.  **数据长度 `n`**: 虽然提供了 64 字节，但密文中只有前 40 字节（10 个 `uint32`）是非零数据。如果原始加密时只处理了 40 字节，那么解密时也必须使用 `n=10` 而不是 `n=16`。\n2.  **Base64 编码**: 在 `sub_401A81` 中调用的 `sub_401898` 极有可能是 Base64 解码。如果 `Str` 是明文输入，它先被 Base64 解码，然后再加密。这意味着我们需要反转这个过程。\n\n### **4. 尝试调整解密长度 (n=10)**\n\n我将尝试仅对前 40 字节进行解密。\n\n\n        \n            \ntoolName: edit_file_search_replace\n            \nstatus: success\n          \n            \nfilePath: e:\\source codes\\xxtea_custom_solve.py\n          \nchanges: undefined\n          \n现在再次运行，观察是否能得到可读内容。\n\n\n        \n            \ntoolName: run_command\n            \nstatus: success\n          \ncommand: python .\\xxtea_custom_solve.py undefined\n          \n成功了！解密后的结果显示为 `moectf{@_N1c3_cup_0f_XXL_te4_1n_2O48}`。\n\n### **解密报告**\n\n**1. 算法特征**\n- **算法**: 自定义 XXTEA (BTEA)。\n- **DELTA**: `0x3E93D719` (1050114489)，而非标准的 `0x9E3779B9`。\n- **密钥**: `2048master2048ma`。\n- **数据长度**: 40 字节 (10 个 32 位整数)，虽然 IDA 显示的数组总长为 64 字节，但只有前 40 字节参与了加密逻辑。\n\n**2. 最终 Flag**\n`moectf{@_N1c3_cup_0f_XXL_te4_1n_2O48}`\n\n**3. 解密脚本总结**\n- 我们识别出 IDA 反汇编代码中的自定义 DELTA。\n- 通过调整解密块长度为 10（即 40 字节），成功还原了明文。\n\n如果您还有其他逆向或密码学问题，欢迎随时提问。"},
		{"id":"85d70512f250d517","x":-5920,"y":7420,"width":920,"height":1884,"type":"text","text":"# xxtea_custom_solve.py\n```python\nimport struct\n\ndef xxtea_decrypt(v, n, k):\n    # 使用代码中发现的自定义 DELTA\n    DELTA = 1050114489 # 0x3E93D719\n    \n    rounds = 6 + 52 // n\n    # 在解密分支中：v14 = 1050114489 * v10\n    sum = (rounds * DELTA) & 0xFFFFFFFF\n    \n    while sum != 0:\n        e = (sum >> 2) & 3\n        # 对应反汇编中的 v19 = *a1; (在解密循环开始前)\n        y = v[0]\n        \n        # 对应 for ( i = v20 - 1; i; --i )\n        for i in range(n - 1, 0, -1):\n            z = v[i-1]\n            # 对应 MX 宏：(((4 * v19) ^ (v16 >> 5)) + ((v19 >> 3) ^ (16 * v16))) ^ ((v19 ^ v14) + (v16 ^ key))\n            mx = (((y << 2 ^ z >> 5) + (y >> 3 ^ z << 4)) ^ ((sum ^ y) + (z ^ k[(i & 3) ^ e])))\n            v[i] = (v[i] - mx) & 0xFFFFFFFF\n            y = v[i]\n        \n        # 对应循环外的最后一次更新\n        z = v[n-1]\n        mx = (((y << 2 ^ z >> 5) + (y >> 3 ^ z << 4)) ^ ((sum ^ y) + (z ^ k[(0 & 3) ^ e])))\n        v[0] = (v[0] - mx) & 0xFFFFFFFF\n        y = v[0]\n        \n        sum = (sum - DELTA) & 0xFFFFFFFF\n    \n    return v\n\ndef solve():\n    # 提供的密文数据\n    ida_chars = [\n        0x35, 0x79, 0x77, 0xCC, 0x1B, 0x13, 0x41, 0x34, 0xF9, 0xFF, \n        0x9F, 0x91, 0xFF, 0x5B, 0x94, 0x78, 0x86, 0x2A, 0xAF, 0xAE, \n        0xD7, 0x9E, 0x31, 0x4D, 0x7A, 0xC4, 0xA5, 0x51, 0xD1, 0xD9, \n        0x6E, 0x44, 0x18, 0x52, 0x86, 0x1B, 0x42, 0x8A, 0xC9, 0x63, \n        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, \n        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, \n        0x00, 0x00, 0x00, 0x00 \n    ]\n    \n    # 转换密文为 10 个 uint32 (前 40 bytes)\n    v = []\n    for i in range(0, 40, 4):\n        v.append(struct.unpack('<I', bytes(ida_chars[i:i+4]))[0])\n        \n    # 准备密钥 (16 bytes -> 4 uint32)\n    key_str = b\"2048master2048ma\"\n    k = []\n    for i in range(0, 16, 4):\n        k.append(struct.unpack('<I', key_str[i:i+4])[0])\n        \n    print(\"[*] 正在使用自定义 DELTA (0x3E93D719) 进行解密...\")\n    res_v = xxtea_decrypt(v, len(v), k)\n    \n    # 还原为字节流\n    res_bytes = b\"\"\n    for x in res_v:\n        res_bytes += struct.pack('<I', x)\n        \n    print(\"[+] 解密原始字节:\", res_bytes)\n    # 尝试寻找 Flag 格式\n    try:\n        decoded = res_bytes.decode('utf-8', errors='ignore').rstrip('\\x00')\n        print(\"[+] 可能的明文内容:\", decoded)\n    except:\n        pass\n\nif __name__ == \"__main__\":\n    solve()\n\n```"},
		{"id":"8480ef6b112a0126","x":-6740,"y":3600,"width":1297,"height":1940,"type":"text","text":"# sub_401530\n```C++\nbool __fastcall sub_401530(unsigned int *a1, int a2, __int64 a3)\n{\n  unsigned int *v3; // rax\n  unsigned int *v4; // rax\n  bool result; // al\n  unsigned int *v6; // rax\n  int v7; // [rsp+8h] [rbp-18h]\n  unsigned int v8; // [rsp+8h] [rbp-18h]\n  int v9; // [rsp+Ch] [rbp-14h]\n  int v10; // [rsp+Ch] [rbp-14h]\n  unsigned int j; // [rsp+10h] [rbp-10h]\n  int i; // [rsp+10h] [rbp-10h]\n  unsigned int v13; // [rsp+14h] [rbp-Ch]\n  unsigned int v14; // [rsp+14h] [rbp-Ch]\n  unsigned int v15; // [rsp+18h] [rbp-8h]\n  unsigned int v16; // [rsp+18h] [rbp-8h]\n  unsigned int v17; // [rsp+18h] [rbp-8h]\n  unsigned int v18; // [rsp+1Ch] [rbp-4h]\n  unsigned int v19; // [rsp+1Ch] [rbp-4h]\n  int v20; // [rsp+38h] [rbp+18h]\n\n  if ( a2 <= 1 )\n  {\n    if ( a2 < -1 )\n    {\n      v20 = -a2;\n      v10 = 52 / -a2 + 6;\n      v14 = 1050114489 * v10;\n      v19 = *a1;\n      do\n      {\n        v8 = (v14 >> 2) & 3;\n        for ( i = v20 - 1; i; --i )\n        {\n          v16 = a1[i - 1];\n          v6 = &a1[i];\n          *v6 -= (((4 * v19) ^ (v16 >> 5)) + ((v19 >> 3) ^ (16 * v16))) ^ ((v19 ^ v14)\n                                                                         + (v16 ^ *(_DWORD *)(4i64 * (v8 ^ i & 3) + a3)));\n          v19 = *v6;\n        }\n        v17 = a1[v20 - 1];\n        *a1 -= (((4 * v19) ^ (v17 >> 5)) + ((v19 >> 3) ^ (16 * v17))) ^ ((v19 ^ v14)\n                                                                       + (v17 ^ *(_DWORD *)(4i64 * v8 + a3)));\n        v19 = *a1;\n        v14 -= 1050114489;\n        result = --v10 != 0;\n      }\n      while ( v10 );\n    }\n  }\n  else\n  {\n    v9 = 52 / a2 + 6;\n    v13 = 0;\n    v15 = a1[a2 - 1];\n    do\n    {\n      v13 += 1050114489;\n      v7 = (v13 >> 2) & 3;\n      for ( j = 0; a2 - 1 > j; ++j )\n      {\n        v18 = a1[j + 1];\n        v3 = &a1[j];\n        *v3 += (((4 * v18) ^ (v15 >> 5)) + ((v18 >> 3) ^ (16 * v15))) ^ ((v18 ^ v13)\n                                                                       + (v15 ^ *(_DWORD *)(4i64 * (v7 ^ j & 3) + a3)));\n        v15 = *v3;\n      }\n      v4 = &a1[a2 - 1];\n      *v4 += (((4 * *a1) ^ (v15 >> 5)) + ((*a1 >> 3) ^ (16 * v15))) ^ ((*a1 ^ v13)\n                                                                     + (v15 ^ *(_DWORD *)(4i64 * (v7 ^ j & 3) + a3)));\n      v15 = *v4;\n      result = --v9 != 0;\n    }\n    while ( v9 );\n  }\n  return result;\n}\n```"},
		{"id":"c073ac01e2450af3","x":-7500,"y":3500,"width":551,"height":580,"type":"text","text":"# sub_401A81\n```C++\n__int64 __fastcall sub_401A81(__int64 a1, __int64 a2, __int64 *a3, __int64 a4)\n{\n  __int64 v5; // rdx\n  __int64 v6[3]; // [rsp+20h] [rbp-30h] BYREF\n  __int64 v7; // [rsp+38h] [rbp-18h] BYREF\n  __int64 v8; // [rsp+40h] [rbp-10h]\n  void *Block; // [rsp+48h] [rbp-8h]\n\n  Block = (void *)sub_401898(a1, a2, &v7);\n  if ( !Block )\n    return 0i64;\n  v5 = a3[1];\n  v6[0] = *a3;\n  v6[1] = v5;\n  sub_401530(Block, (unsigned int)v7, v6);\n  v8 = sub_40195B(Block, v7, a4);\n  free(Block);\n  return v8;\n}\n```"},
		{"id":"e50edd3594690b0e","x":-8560,"y":3440,"width":905,"height":931,"type":"text","text":"```C\n__int64 sub_401C83()\n{\n  __int64 v1; // rax\n  char Str[136]; // [rsp+20h] [rbp-D0h] BYREF\n  unsigned __int64 v3; // [rsp+A8h] [rbp-48h] BYREF\n  __int64 v4[4]; // [rsp+B0h] [rbp-40h] BYREF\n  void *Block; // [rsp+D0h] [rbp-20h]\n  FILE *Stream; // [rsp+D8h] [rbp-18h]\n  unsigned __int64 i; // [rsp+E0h] [rbp-10h]\n  unsigned int v8; // [rsp+ECh] [rbp-4h]\n\n  Stream = fopen(\"flag.txt\", \"r\");\n  scanf((__int64)Stream, \"%100s\", Str);\n  fclose(Stream);\n  if ( strlen(Str) != 37 )\n    return 1i64;\n  strcpy((char *)v4, \"2048master2048ma\");\n  v1 = strlen(Str);\n  Block = (void *)sub_401A81((__int64)Str, v1, v4, (__int64)&v3);\n  if ( Block )\n  {\n    v8 = 0;\n    for ( i = 0i64; i < v3; ++i )\n    {\n      if ( *((_BYTE *)Block + i) != byte_495280[i] )\n        v8 = 1;\n    }\n    free(Block);\n    return v8;\n  }\n  else\n  {\n    sub_428D00(\"Encryption failed\\n\");\n    return 1i64;\n  }\n}\n```"}
