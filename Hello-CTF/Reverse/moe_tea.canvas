		{"id":"ac8dea99dc631b82","x":-125,"y":-30,"width":825,"height":1530,"type":"text","text":"```C\nint __fastcall main(int argc, const char **argv, const char **envp)\n{\n  __int64 v3; // rbx\n  FILE *v4; // rax\n  size_t v5; // rax\n  __int64 v6; // rdx\n  __int64 v7; // rax\n  char *v8; // rcx\n  __int64 v10; // [rsp+20h] [rbp-E0h] BYREF\n  char v11; // [rsp+28h] [rbp-D8h]\n  __int64 v12; // [rsp+30h] [rbp-D0h] BYREF\n  int v13; // [rsp+38h] [rbp-C8h]\n  int v14; // [rsp+3Ch] [rbp-C4h]\n  int v15[10]; // [rsp+40h] [rbp-C0h]\n  __int128 v16[2]; // [rsp+68h] [rbp-98h] BYREF\n  __int64 v17; // [rsp+88h] [rbp-78h]\n  char Buffer[16]; // [rsp+90h] [rbp-70h] BYREF\n  __int128 v19; // [rsp+A0h] [rbp-60h]\n  __int64 v20; // [rsp+B0h] [rbp-50h]\n\n  v3 = 0i64;\n  v12 = 2i64;\n  v11 = 0;\n  v13 = 2;\n  v14 = 5;\n  v15[0] = 1566723124;\n  v15[1] = -2044068179;\n  v15[2] = -1659816037;\n  v15[3] = -53136879;\n  v15[4] = 1175413710;\n  v15[5] = -981373336;\n  v15[6] = -28114771;\n  v15[7] = 167777774;\n  v15[8] = -1744380997;\n  v15[9] = -280353208;\n  v10 = 0xD0FCC6A7B8941CAFui64;\n  sub_140001070(argc, &v10, &v12);\n  sub_140001010(Format);\n  v4 = _acrt_iob_func(0);\n  fgets(Buffer, 100, v4);\n  v5 = strcspn(Buffer, \"\\n\");\n  if ( v5 >= 0x64 )\n    sub_140001BE8();\n  Buffer[v5] = 0;\n  v16[0] = *(_OWORD *)Buffer;\n  v12 = v10;\n  v17 = v20;\n  v16[1] = v19;\n  v13 = 305419896;\n  v14 = -1698898192;\n  sub_1400015E0(v16, v6, &v12);\n  v7 = -1i64;\n  do\n    ++v7;\n  while ( Buffer[v7] );\n  if ( v7 == 40 )\n  {\n    while ( *(_DWORD *)((char *)v16 + v3 * 4) == v15[v3] )\n    {\n      if ( ++v3 >= 10 )\n      {\n        v8 = (char *)&unk_1400032C0;\n        goto LABEL_10;\n      }\n    }\n    v8 = \"flag错误,请重新输入\";\n  }\n  else\n  {\n    v8 = \"长度错误\";\n  }\nLABEL_10:\n  sub_140001010(v8);\n  return 0;\n}\n```"},
